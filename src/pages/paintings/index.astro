---
import { getCollection } from "astro:content"
import BaseLayout from "../../layouts/BaseLayout.astro"
import ArtworkCard from "../../components/ArtworkCard.astro"
import { LINKS } from "../../constants/constants"
import { coverTransitionName } from "../../utils/coverTransitionName"

const paintings = (await getCollection("paintings")).sort((a, b) => b.data.year - a.data.year)
---

<BaseLayout title="Painting Gallery">
    <main class="gallery-page">
        <h1>Paintings</h1>
        <ul class="gallery">
            {
                paintings.map((artwork) => {
                    const cover = artwork.data.images[0]
                    const hasDetailPage = artwork.data.images.length > 1 || Boolean(artwork.data.video)
                    return (
                        <li>
                            <ArtworkCard
                                cover={cover.src}
                                alt={cover.alt}
                                title={artwork.data.title}
                                year={artwork.data.year}
                                medium={artwork.data.medium}
                                href={hasDetailPage ? `${LINKS.paintings}/${artwork.id}` : undefined}
                                transitionName={
                                    hasDetailPage ? coverTransitionName(artwork.collection, artwork.id) : undefined
                                }
                            />
                        </li>
                    )
                })
            }
        </ul>
    </main>
</BaseLayout>

<style>
    .gallery-page {
        max-width: var(--content-max-width);
        margin-inline: auto;
        padding: var(--spacing-500) var(--spacing-gutter);
    }

    h1 {
        margin-block-end: var(--spacing-500);
    }

    .gallery {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--spacing-500);
        margin: 0;
        padding: 0;
        list-style: none;
    }

    @media (max-width: 40em) {
        .gallery {
            grid-template-columns: 1fr;
        }
    }
</style>
