---
import { getCollection } from "astro:content"
import { Image, getImage } from "astro:assets"
import BaseLayout from "../layouts/BaseLayout.astro"
import { LINKS } from "../constants/constants"

type Yearable = { data: { year: number } }
const byYearDesc = <T extends Yearable>(a: T, b: T) => b.data.year - a.data.year
const painting = (await getCollection("paintings")).sort(byYearDesc)[0]
const ceramic = (await getCollection("ceramics")).sort(byYearDesc)[0]

const panels = [
    {
        cover: painting.data.images[0],
        href: LINKS.paintings,
        name: "Abstract Painting",
    },
    { cover: ceramic.data.images[0], href: LINKS.ceramics, name: "Ceramics" },
]

const widths = [768, 1280, 1920, 2560]
const sizes = "(min-width: 48em) 50vw, 100vw"

const preloads = await Promise.all(
    panels.map(({ cover }) => getImage({ src: cover.src, format: "webp", widths, sizes })),
)
---

<BaseLayout title="Josephine Florence - Painter / Ceramicist">
    <Fragment slot="head">
        {
            preloads.map((img) => (
                <link
                    rel="preload"
                    as="image"
                    type="image/webp"
                    imagesrcset={img.srcSet.attribute}
                    imagesizes={sizes}
                />
            ))
        }
    </Fragment>

    <h1 class="visually-hidden">Josephine Florence — Abstract Painter / Ceramicist</h1>

    <div class="hero">
        {
            panels.map(({ cover, href, name }) => (
                <a class="hero__panel" href={href} aria-label={name}>
                    <Image
                        src={cover.src}
                        alt={cover.alt}
                        format="webp"
                        widths={widths}
                        sizes={sizes}
                        loading="eager"
                        fetchpriority="high"
                    />
                    <span class="hero__label" aria-hidden="true">
                        {name}
                    </span>
                </a>
            ))
        }
    </div>
</BaseLayout>

<style>
    .hero {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(calc(var(--breakpoint-md) / 2), 1fr));
        row-gap: var(--spacing-200);

        margin-block-end: var(--spacing-500);
    }

    .hero__panel {
        position: relative;
        display: block;
        overflow: hidden;
        height: 70svh;
    }

    .hero__panel :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .hero__label {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        padding: var(--spacing-300);
        text-align: center;

        font-family: var(--font-display);
        font-size: var(--font-size-700);
        color: var(--color-surface);
        background: var(--color-ink-scrim);

        opacity: 0;
        transition: opacity var(--transition-duration) ease;
    }

    .hero__panel:hover .hero__label,
    .hero__panel:focus-visible .hero__label {
        opacity: 1;
    }

    @media (min-width: 48em) {
        .hero {
            height: 80svh;
        }
        .hero__panel {
            height: 100%;
        }
    }
</style>
