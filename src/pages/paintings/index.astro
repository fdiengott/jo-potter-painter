---
import { getCollection } from "astro:content"
import BaseLayout from "../../layouts/BaseLayout.astro"
import { groupArtworksByYear } from "../../utils/groupArtworksByYear"
import GallerySectionList from "../../components/GallerySectionList.astro"

const sections = groupArtworksByYear(await getCollection("paintings"))
---

<BaseLayout title="Painting Gallery">
    <main class="gallery-page">
        <h1>Paintings</h1>
        <GallerySectionList sections={sections} />
    </main>
</BaseLayout>

<style>
    .gallery-page {
        max-width: var(--content-max-width);
        margin-inline: auto;
        padding: var(--spacing-500) var(--spacing-gutter);
    }

    h1 {
        margin-block-end: var(--spacing-500);
    }
</style>
