---
import { Picture } from "astro:assets"
import type { CollectionEntry } from "astro:content"
import { coverTransitionName } from "../utils/coverTransitionName"

interface Props {
    artwork: CollectionEntry<"paintings"> | CollectionEntry<"ceramics">
}

const { artwork } = Astro.props
const { title, year, medium, images, videoSrc } = artwork.data

const coverName = coverTransitionName(artwork.collection, artwork.id)

function youtubeEmbed(url: string): string | null {
    try {
        const u = new URL(url)
        let id = ""
        if (u.hostname === "youtu.be") id = u.pathname.slice(1)
        else if (u.pathname.startsWith("/embed/")) id = u.pathname.split("/")[2]
        else id = u.searchParams.get("v") ?? ""
        return id ? `https://www.youtube-nocookie.com/embed/${id}` : null
    } catch {
        return null
    }
}

const embedUrl = videoSrc ? youtubeEmbed(videoSrc) : null
---

<main class="artwork">
    <header class="artwork__header">
        <h1 class="artwork__title">{title}</h1>
        <p class="artwork__meta">{year} {medium && `· ${medium}`}</p>
    </header>

    <ul class="artwork__images">
        {
            images.map((img, i) => (
                <li>
                    <Picture
                        src={img.src}
                        formats={["avif", "webp"]}
                        alt={img.alt}
                        widths={[400, 800, 1200, 1600]}
                        sizes="(min-width: 72rem) 72rem, 100vw"
                        loading={i === 0 ? "eager" : "lazy"}
                        style={i === 0 ? `view-transition-name: ${coverName}` : undefined}
                    />
                </li>
            ))
        }
    </ul>

    {
        embedUrl && (
            <div class="artwork__video">
                <iframe
                    src={embedUrl}
                    title={`${title} — video`}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                />
            </div>
        )
    }

    <div class="artwork__body">
        <slot />
    </div>
</main>

<style>
    .artwork {
        max-width: var(--content-max-width);
        margin-inline: auto;
        padding: var(--spacing-500) var(--spacing-gutter);
    }

    .artwork__header {
        margin-block-end: var(--spacing-500);
    }

    .artwork__title {
        margin: 0;
    }

    .artwork__meta {
        margin-block-start: var(--spacing-100);
        font-size: var(--font-size-400);
        color: var(--color-ink-muted);
    }

    .artwork__images {
        display: grid;
        gap: var(--spacing-400);
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .artwork__images :global(img) {
        display: block;
        width: 100%;
        height: auto;
        border-radius: var(--radius-400);
        background: var(--color-border);
    }

    .artwork__video {
        margin-block-start: var(--spacing-400);
        aspect-ratio: 16 / 9;
        border-radius: var(--radius-400);
        overflow: hidden;
        background: var(--color-border);
    }

    .artwork__video iframe {
        display: block;
        width: 100%;
        height: 100%;
        border: 0;
    }

    .artwork__body {
        max-width: var(--content-measure);
        margin-block-start: var(--spacing-500);
        line-height: var(--line-height-400);
    }
</style>
